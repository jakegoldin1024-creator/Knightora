{
  "name": "knightora",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stable": "WATCHPACK_POLLING=true next dev --hostname 127.0.0.1 --port 3000",
    "dev:stable:webpack": "WATCHPACK_POLLING=true next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "smoke:game-analysis": "node --experimental-strip-types scripts/smoke-game-analysis.mts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/billing/webhook"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@lichess-org/stockfish-web": "^0.2.3",
    "chess.js": "^1.4.0",
    "next": "^16.2.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "stripe": "^18.4.0"
  },
  "devDependencies": {
    "@types/node": "22.13.11",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "eslint": "^9.22.0",
    "eslint-config-next": "^16.0.10",
    "typescript": "5.8.2"
  }
}

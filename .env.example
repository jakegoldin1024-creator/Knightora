KNIGHTNEO_ADMIN_CODE=replace-me
# API also accepts legacy admin env keys (previous deploy) if the KNIGHTNEO_* vars above are unset.

# Clerk (sign-in / sign-up) — from https://dashboard.clerk.com
# Use publishable + secret keys from the SAME Clerk application (same instance).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Recommended so OAuth (e.g. Apple) round-trips resolve to your app routes:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
# If you use production Apple Sign In: Apple Developer “Return URL” must match the
# value shown in Clerk Dashboard → SSO → Apple (it changes if you create a new Clerk app).

# Stripe — from https://dashboard.stripe.com (Test mode for local dev)
# 1) Developers → API keys → Secret key
STRIPE_SECRET_KEY=sk_test_replace_me
# 2) Products: one product (e.g. Knightneo) with two recurring prices (monthly + yearly).
#    Copy each Price ID (price_...) below. See README “Real Stripe billing setup”.
#    Knightneo reads the FIRST non-empty variable in each list (see lib/billing.ts).
STRIPE_PRICE_PAID_MONTHLY=price_replace_me_monthly
STRIPE_PRICE_PAID_YEARLY=price_replace_me_yearly
# Legacy / alternate names (optional)
# STRIPE_PRICE_STARTER=price_replace_me_monthly
# STRIPE_PRICE_ID=price_replace_me_monthly
# STRIPE_PRICE_YEARLY=price_replace_me_yearly
# Single-tier apps sometimes use:
# STRIPE_SUBSCRIPTION_PRICE_ID=price_replace_me_monthly
# Client-visible fallback (price IDs are public in Checkout anyway):
# NEXT_PUBLIC_STRIPE_PRICE_ID=price_replace_me_monthly
# NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_replace_me_yearly
# 3) Webhook signing secret: use `npm run stripe:listen` locally (whsec_ from CLI),
#    or Stripe Dashboard → Webhooks → endpoint signing secret in production.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# OpenAI — used by game-analysis coach summaries and the /coach chat (streaming + tools).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_replace_me
# Optional overrides (defaults are set in code).
# OPENAI_COACH_MODEL=gpt-4.1-mini
# OPENAI_COACH_CHAT_MODEL=gpt-4o-mini

KNIGHTORA_ADMIN_CODE=replace-me

# Clerk (sign-in / sign-up) — from https://dashboard.clerk.com
# Use publishable + secret keys from the SAME Clerk application (same instance).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Recommended so OAuth (e.g. Apple) round-trips resolve to your app routes:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
# If you use production Apple Sign In: Apple Developer “Return URL” must match the
# value shown in Clerk Dashboard → SSO → Apple (it changes if you create a new Clerk app).

# Stripe setup
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_CLUB=price_replace_me
STRIPE_PRICE_PRO=price_replace_me
